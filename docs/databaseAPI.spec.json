{
  "openapi": "3.0.3",
  "info": {
    "title": "Workout Programming SPA - Database API",
    "description": "Internal API abstraction layer for the Workout Programming SPA. Mirrors the client-side SQLite schema and is structured for future migration to a REST backend. No authentication is required at this stage.",
    "version": "1.0.0"
  },
  "tags": [
    { "name": "Mesocycles", "description": "Training programs containing multiple workouts" },
    { "name": "Workouts", "description": "Individual workout sessions within a mesocycle" },
    { "name": "Workout Groups", "description": "Muscle group categories (e.g. Push, Pull, Legs)" },
    { "name": "Exercises", "description": "Exercises assigned to workout groups" },
    { "name": "Workout Group Selections", "description": "Which workout groups are assigned to a specific workout" },
    { "name": "Workout Sets", "description": "Sets performed within a workout for a given exercise" },
    { "name": "Child Sets", "description": "Drop sets, supersets, or other sub-sets under a parent set" }
  ],
  "paths": {

    "/mesocycles": {
      "get": {
        "tags": ["Mesocycles"],
        "summary": "List all mesocycles",
        "operationId": "listMesocycles",
        "responses": {
          "200": {
            "description": "A list of mesocycles",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Mesocycle" }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Mesocycles"],
        "summary": "Create a new mesocycle",
        "operationId": "createMesocycle",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/MesocycleInput" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Mesocycle created successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Mesocycle" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },

    "/mesocycles/{mesocycleId}": {
      "parameters": [
        { "$ref": "#/components/parameters/mesocycleId" }
      ],
      "get": {
        "tags": ["Mesocycles"],
        "summary": "Get a mesocycle by ID",
        "operationId": "getMesocycle",
        "responses": {
          "200": {
            "description": "The requested mesocycle",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Mesocycle" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "tags": ["Mesocycles"],
        "summary": "Update a mesocycle",
        "operationId": "updateMesocycle",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/MesocycleInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Mesocycle updated successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Mesocycle" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Mesocycles"],
        "summary": "Delete a mesocycle",
        "description": "Deletes the mesocycle and cascades deletion to all associated workouts, workout group selections, and workout sets.",
        "operationId": "deleteMesocycle",
        "responses": {
          "204": { "description": "Mesocycle deleted successfully" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },

    "/mesocycles/{mesocycleId}/workouts": {
      "parameters": [
        { "$ref": "#/components/parameters/mesocycleId" }
      ],
      "get": {
        "tags": ["Workouts"],
        "summary": "List workouts in a mesocycle",
        "operationId": "listWorkouts",
        "responses": {
          "200": {
            "description": "Ordered list of workouts in the mesocycle",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Workout" }
                }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "post": {
        "tags": ["Workouts"],
        "summary": "Create a workout in a mesocycle",
        "operationId": "createWorkout",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/WorkoutInput" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Workout created successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Workout" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },

    "/workouts/{workoutId}": {
      "parameters": [
        { "$ref": "#/components/parameters/workoutId" }
      ],
      "get": {
        "tags": ["Workouts"],
        "summary": "Get a workout by ID",
        "operationId": "getWorkout",
        "responses": {
          "200": {
            "description": "The requested workout",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Workout" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "tags": ["Workouts"],
        "summary": "Update a workout",
        "operationId": "updateWorkout",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/WorkoutInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Workout updated successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Workout" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Workouts"],
        "summary": "Delete a workout",
        "description": "Deletes the workout and cascades deletion to all associated workout group selections and workout sets.",
        "operationId": "deleteWorkout",
        "responses": {
          "204": { "description": "Workout deleted successfully" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },

    "/workout-groups": {
      "get": {
        "tags": ["Workout Groups"],
        "summary": "List all workout groups",
        "operationId": "listWorkoutGroups",
        "responses": {
          "200": {
            "description": "A list of workout groups",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/WorkoutGroup" }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Workout Groups"],
        "summary": "Create a workout group",
        "operationId": "createWorkoutGroup",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/WorkoutGroupInput" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Workout group created successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WorkoutGroup" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      }
    },

    "/workout-groups/{workoutGroupId}": {
      "parameters": [
        { "$ref": "#/components/parameters/workoutGroupId" }
      ],
      "get": {
        "tags": ["Workout Groups"],
        "summary": "Get a workout group by ID",
        "operationId": "getWorkoutGroup",
        "responses": {
          "200": {
            "description": "The requested workout group",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WorkoutGroup" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "tags": ["Workout Groups"],
        "summary": "Update a workout group",
        "operationId": "updateWorkoutGroup",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/WorkoutGroupInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Workout group updated successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WorkoutGroup" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      },
      "delete": {
        "tags": ["Workout Groups"],
        "summary": "Delete a workout group",
        "description": "Deletes the workout group and cascades deletion to all associated exercises.",
        "operationId": "deleteWorkoutGroup",
        "responses": {
          "204": { "description": "Workout group deleted successfully" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },

    "/workout-groups/{workoutGroupId}/exercises": {
      "parameters": [
        { "$ref": "#/components/parameters/workoutGroupId" }
      ],
      "get": {
        "tags": ["Exercises"],
        "summary": "List exercises in a workout group",
        "operationId": "listExercisesByWorkoutGroup",
        "responses": {
          "200": {
            "description": "A list of exercises in the specified workout group",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Exercise" }
                }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "post": {
        "tags": ["Exercises"],
        "summary": "Create an exercise in a workout group",
        "operationId": "createExercise",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ExerciseInput" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Exercise created successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Exercise" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },

    "/exercises": {
      "get": {
        "tags": ["Exercises"],
        "summary": "List all exercises",
        "description": "Returns all exercises across all workout groups. Use the workoutGroupId query parameter to filter.",
        "operationId": "listExercises",
        "parameters": [
          {
            "name": "workoutGroupId",
            "in": "query",
            "description": "Filter exercises by workout group ID",
            "required": false,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "A list of exercises",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Exercise" }
                }
              }
            }
          }
        }
      }
    },

    "/exercises/{exerciseId}": {
      "parameters": [
        { "$ref": "#/components/parameters/exerciseId" }
      ],
      "get": {
        "tags": ["Exercises"],
        "summary": "Get an exercise by ID",
        "operationId": "getExercise",
        "responses": {
          "200": {
            "description": "The requested exercise",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Exercise" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "tags": ["Exercises"],
        "summary": "Update an exercise",
        "operationId": "updateExercise",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ExerciseInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Exercise updated successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Exercise" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Exercises"],
        "summary": "Delete an exercise",
        "operationId": "deleteExercise",
        "responses": {
          "204": { "description": "Exercise deleted successfully" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },

    "/workouts/{workoutId}/workout-groups": {
      "parameters": [
        { "$ref": "#/components/parameters/workoutId" }
      ],
      "get": {
        "tags": ["Workout Group Selections"],
        "summary": "List workout groups assigned to a workout",
        "operationId": "listWorkoutGroupSelections",
        "responses": {
          "200": {
            "description": "Workout groups selected for the workout",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/WorkoutGroupSelection" }
                }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "post": {
        "tags": ["Workout Group Selections"],
        "summary": "Assign a workout group to a workout",
        "operationId": "addWorkoutGroupSelection",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/WorkoutGroupSelectionInput" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Workout group assigned successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WorkoutGroupSelection" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      }
    },

    "/workouts/{workoutId}/workout-groups/{workoutGroupId}": {
      "parameters": [
        { "$ref": "#/components/parameters/workoutId" },
        { "$ref": "#/components/parameters/workoutGroupId" }
      ],
      "delete": {
        "tags": ["Workout Group Selections"],
        "summary": "Remove a workout group from a workout",
        "operationId": "removeWorkoutGroupSelection",
        "responses": {
          "204": { "description": "Workout group removed from workout successfully" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },

    "/workouts/{workoutId}/workout-sets": {
      "parameters": [
        { "$ref": "#/components/parameters/workoutId" }
      ],
      "get": {
        "tags": ["Workout Sets"],
        "summary": "List workout sets for a workout",
        "description": "Returns all sets for the given workout. Use the grouped query parameter to receive sets grouped by exercise.",
        "operationId": "listWorkoutSets",
        "parameters": [
          {
            "name": "grouped",
            "in": "query",
            "description": "When true, returns sets grouped by exercise as an array of exercise objects each containing a sets array.",
            "required": false,
            "schema": { "type": "boolean", "default": false }
          },
          {
            "name": "exerciseId",
            "in": "query",
            "description": "Filter sets by a specific exercise ID",
            "required": false,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Workout sets for the specified workout",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/WorkoutSet" }
                    },
                    {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/WorkoutSetsByExercise" }
                    }
                  ]
                }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "post": {
        "tags": ["Workout Sets"],
        "summary": "Create a workout set",
        "operationId": "createWorkoutSet",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/WorkoutSetInput" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Workout set created successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WorkoutSet" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Workout Sets"],
        "summary": "Delete all sets in a workout",
        "description": "Removes all workout sets (and their child sets) for the specified workout. Useful for clearing a workout before rebuilding.",
        "operationId": "deleteAllWorkoutSets",
        "responses": {
          "204": { "description": "All sets deleted successfully" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },

    "/workout-sets/{workoutSetId}": {
      "parameters": [
        { "$ref": "#/components/parameters/workoutSetId" }
      ],
      "get": {
        "tags": ["Workout Sets"],
        "summary": "Get a workout set by ID",
        "operationId": "getWorkoutSet",
        "responses": {
          "200": {
            "description": "The requested workout set",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WorkoutSet" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "tags": ["Workout Sets"],
        "summary": "Update a workout set",
        "operationId": "updateWorkoutSet",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/WorkoutSetInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Workout set updated successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WorkoutSet" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Workout Sets"],
        "summary": "Delete a workout set",
        "description": "Deletes the workout set and cascades deletion to all child sets.",
        "operationId": "deleteWorkoutSet",
        "responses": {
          "204": { "description": "Workout set deleted successfully" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },

    "/workout-sets/{workoutSetId}/child-sets": {
      "parameters": [
        { "$ref": "#/components/parameters/workoutSetId" }
      ],
      "get": {
        "tags": ["Child Sets"],
        "summary": "List child sets for a workout set",
        "description": "Returns all child sets (e.g. drop sets, superset exercises) belonging to the parent workout set.",
        "operationId": "listChildSets",
        "responses": {
          "200": {
            "description": "Child sets for the specified parent workout set",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/ChildSet" }
                }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "post": {
        "tags": ["Child Sets"],
        "summary": "Create a child set",
        "operationId": "createChildSet",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ChildSetInput" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Child set created successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ChildSet" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },

    "/child-sets/{childSetId}": {
      "parameters": [
        { "$ref": "#/components/parameters/childSetId" }
      ],
      "get": {
        "tags": ["Child Sets"],
        "summary": "Get a child set by ID",
        "operationId": "getChildSet",
        "responses": {
          "200": {
            "description": "The requested child set",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ChildSet" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "tags": ["Child Sets"],
        "summary": "Update a child set",
        "operationId": "updateChildSet",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ChildSetInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Child set updated successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ChildSet" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Child Sets"],
        "summary": "Delete a child set",
        "operationId": "deleteChildSet",
        "responses": {
          "204": { "description": "Child set deleted successfully" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    }

  },

  "components": {

    "parameters": {
      "mesocycleId": {
        "name": "mesocycleId",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" },
        "description": "The unique ID of the mesocycle"
      },
      "workoutId": {
        "name": "workoutId",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" },
        "description": "The unique ID of the workout"
      },
      "workoutGroupId": {
        "name": "workoutGroupId",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" },
        "description": "The unique ID of the workout group"
      },
      "exerciseId": {
        "name": "exerciseId",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" },
        "description": "The unique ID of the exercise"
      },
      "workoutSetId": {
        "name": "workoutSetId",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" },
        "description": "The unique ID of the workout set"
      },
      "childSetId": {
        "name": "childSetId",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" },
        "description": "The unique ID of the child set"
      }
    },

    "schemas": {

      "Mesocycle": {
        "type": "object",
        "description": "A training program block containing an ordered set of workouts",
        "properties": {
          "id": { "type": "integer", "readOnly": true, "example": 1 },
          "program_name": { "type": "string", "example": "Hypertrophy Block 1" },
          "start_date": { "type": "string", "format": "date", "example": "2026-03-24" },
          "notes": { "type": "string", "nullable": true, "example": "Focus on progressive overload each week" }
        },
        "required": ["id", "program_name", "start_date"]
      },

      "MesocycleInput": {
        "type": "object",
        "description": "Fields required to create or update a mesocycle",
        "properties": {
          "program_name": { "type": "string", "example": "Hypertrophy Block 1" },
          "start_date": { "type": "string", "format": "date", "example": "2026-03-24" },
          "notes": { "type": "string", "nullable": true, "example": "Focus on progressive overload each week" },
          "microcycle_length": { "type": "integer", "example": 7, "description": "Number of days in each microcycle (e.g. 7 for a weekly cycle)" }
        },
        "required": ["program_name", "start_date", "microcycle_length"]
      },

      "Workout": {
        "type": "object",
        "description": "An individual workout session within a mesocycle",
        "properties": {
          "id": { "type": "integer", "readOnly": true, "example": 1 },
          "mesocycle_id": { "type": "integer", "example": 1 },
          "workout_name": { "type": "string", "example": "Day 1 - Push" },
          "workout_order": { "type": "integer", "description": "Unique order position within the mesocycle", "example": 1 },
          "notes": { "type": "string", "nullable": true, "example": "Focus on chest activation" }
        },
        "required": ["id", "mesocycle_id", "workout_name", "workout_order"]
      },

      "WorkoutInput": {
        "type": "object",
        "description": "Fields required to create or update a workout",
        "properties": {
          "workout_name": { "type": "string", "example": "Day 1 - Push" },
          "workout_order": { "type": "integer", "example": 1 },
          "notes": { "type": "string", "nullable": true, "example": "Focus on chest activation" }
        },
        "required": ["workout_name", "workout_order"]
      },

      "WorkoutGroup": {
        "type": "object",
        "description": "A muscle group or category (e.g. Push, Pull, Legs, Rest)",
        "properties": {
          "id": { "type": "integer", "readOnly": true, "example": 1 },
          "name": { "type": "string", "example": "Push" },
          "notes": { "type": "string", "nullable": true, "example": "Chest, shoulders, triceps" }
        },
        "required": ["id", "name"]
      },

      "WorkoutGroupInput": {
        "type": "object",
        "description": "Fields required to create or update a workout group",
        "properties": {
          "name": { "type": "string", "example": "Push" },
          "notes": { "type": "string", "nullable": true, "example": "Chest, shoulders, triceps" }
        },
        "required": ["name"]
      },

      "Exercise": {
        "type": "object",
        "description": "An exercise belonging to a workout group",
        "properties": {
          "id": { "type": "integer", "readOnly": true, "example": 1 },
          "workout_group_id": { "type": "integer", "example": 1 },
          "name": { "type": "string", "example": "Barbell Bench Press" },
          "tutorial_url": { "type": "string", "format": "uri", "nullable": true, "example": "https://youtube.com/watch?v=example" },
          "notes": { "type": "string", "nullable": true, "example": "Keep shoulder blades retracted" }
        },
        "required": ["id", "workout_group_id", "name"]
      },

      "ExerciseInput": {
        "type": "object",
        "description": "Fields required to create or update an exercise",
        "properties": {
          "name": { "type": "string", "example": "Barbell Bench Press" },
          "tutorial_url": { "type": "string", "format": "uri", "nullable": true, "example": "https://youtube.com/watch?v=example" },
          "notes": { "type": "string", "nullable": true, "example": "Keep shoulder blades retracted" }
        },
        "required": ["name"]
      },

      "WorkoutGroupSelection": {
        "type": "object",
        "description": "A junction record assigning a workout group to a specific workout",
        "properties": {
          "id": { "type": "integer", "readOnly": true, "example": 1 },
          "workout_id": { "type": "integer", "example": 1 },
          "workout_group_id": { "type": "integer", "example": 2 },
          "workout_group": { "$ref": "#/components/schemas/WorkoutGroup" }
        },
        "required": ["id", "workout_id", "workout_group_id"]
      },

      "WorkoutGroupSelectionInput": {
        "type": "object",
        "description": "Fields required to assign a workout group to a workout",
        "properties": {
          "workout_group_id": { "type": "integer", "example": 2 }
        },
        "required": ["workout_group_id"]
      },

      "WorkoutSet": {
        "type": "object",
        "description": "A single set performed for an exercise within a workout",
        "properties": {
          "id": { "type": "integer", "readOnly": true, "example": 1 },
          "workout_id": { "type": "integer", "example": 1 },
          "exercise_id": { "type": "integer", "example": 3 },
          "exercise_order": { "type": "integer", "description": "Display order of the exercise within the workout", "example": 1 },
          "set_number": { "type": "integer", "description": "The set number for this exercise (1, 2, 3...)", "example": 1 },
          "reps": { "type": "integer", "nullable": true, "example": 10 },
          "weight": { "type": "number", "format": "float", "nullable": true, "description": "Weight in the user's preferred unit", "example": 100.0 },
          "rir": { "type": "integer", "nullable": true, "description": "Reps In Reserve (0 = failure, higher = more left in the tank)", "example": 2 },
          "notes": { "type": "string", "nullable": true, "example": "Felt strong today" }
        },
        "required": ["id", "workout_id", "exercise_id", "exercise_order", "set_number"]
      },

      "WorkoutSetInput": {
        "type": "object",
        "description": "Fields required to create or update a workout set",
        "properties": {
          "exercise_id": { "type": "integer", "example": 3 },
          "exercise_order": { "type": "integer", "example": 1 },
          "set_number": { "type": "integer", "example": 1 },
          "reps": { "type": "integer", "nullable": true, "example": 10 },
          "weight": { "type": "number", "format": "float", "nullable": true, "example": 100.0 },
          "rir": { "type": "integer", "nullable": true, "example": 2 },
          "notes": { "type": "string", "nullable": true, "example": "Felt strong today" }
        },
        "required": ["exercise_id", "exercise_order", "set_number"]
      },

      "WorkoutSetsByExercise": {
        "type": "object",
        "description": "Workout sets grouped by exercise - returned when grouped=true query param is used",
        "properties": {
          "exercise_id": { "type": "integer", "example": 3 },
          "exercise_name": { "type": "string", "example": "Barbell Bench Press" },
          "exercise_order": { "type": "integer", "example": 1 },
          "sets": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/WorkoutSet" }
          }
        },
        "required": ["exercise_id", "exercise_name", "exercise_order", "sets"]
      },

      "ChildSet": {
        "type": "object",
        "description": "A child set belonging to a parent workout set. Used for drop sets, supersets, etc.",
        "properties": {
          "id": { "type": "integer", "readOnly": true, "example": 1 },
          "parent_set_id": { "type": "integer", "example": 5 },
          "exercise_id": { "type": "integer", "example": 3 },
          "exercise_order": { "type": "integer", "description": "Display order of this child set within the parent", "example": 1 },
          "reps": { "type": "integer", "nullable": true, "example": 8 },
          "weight": { "type": "number", "format": "float", "nullable": true, "example": 80.0 },
          "rir": { "type": "integer", "nullable": true, "example": 0 },
          "notes": { "type": "string", "nullable": true, "example": "Drop set" }
        },
        "required": ["id", "parent_set_id", "exercise_id", "exercise_order"]
      },

      "ChildSetInput": {
        "type": "object",
        "description": "Fields required to create or update a child set",
        "properties": {
          "exercise_id": { "type": "integer", "example": 3 },
          "exercise_order": { "type": "integer", "example": 1 },
          "reps": { "type": "integer", "nullable": true, "example": 8 },
          "weight": { "type": "number", "format": "float", "nullable": true, "example": 80.0 },
          "rir": { "type": "integer", "nullable": true, "example": 0 },
          "notes": { "type": "string", "nullable": true, "example": "Drop set" }
        },
        "required": ["exercise_id", "exercise_order"]
      },

      "Error": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "error": { "type": "string", "example": "Resource not found" },
          "code": { "type": "string", "example": "NOT_FOUND" }
        },
        "required": ["success", "error"]
      }
    },

    "responses": {
      "BadRequest": {
        "description": "Invalid input or missing required fields",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" },
            "example": {
              "success": false,
              "error": "workout_name is required",
              "code": "VALIDATION_ERROR"
            }
          }
        }
      },
      "NotFound": {
        "description": "The requested resource was not found",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" },
            "example": {
              "success": false,
              "error": "Resource not found",
              "code": "NOT_FOUND"
            }
          }
        }
      },
      "Conflict": {
        "description": "A resource with conflicting unique constraints already exists",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" },
            "example": {
              "success": false,
              "error": "A workout group with this name already exists",
              "code": "CONFLICT"
            }
          }
        }
      }
    }

  }
}
